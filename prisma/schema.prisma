generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  active
  archived
}

enum AssetViewerLayout {
  grid
  compare_2
  compare_4
}

enum JobState {
  queued
  running
  succeeded
  failed
  canceled
}

enum AssetType {
  image
  video
  text
}

model Project {
  id             String                 @id @default(cuid())
  name           String
  status         ProjectStatus          @default(active)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  lastOpenedAt   DateTime?
  workspaceState ProjectWorkspaceState?
  canvas         Canvas?
  nodes          CanvasNode[]
  edges          CanvasEdge[]
  jobs           Job[]
  assets         Asset[]
  tags           AssetTag[]

  @@index([status, updatedAt(sort: Desc)])
}

model ProjectWorkspaceState {
  projectId         String            @id
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  isOpen            Boolean           @default(false)
  viewportState     Json?
  selectionState    Json?
  assetViewerLayout AssetViewerLayout @default(grid)
  filterState       Json?
  updatedAt         DateTime          @updatedAt
}

model Canvas {
  projectId      String   @id
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  canvasDocument Json?
  version        Int      @default(1)
  updatedAt      DateTime @updatedAt
}

model CanvasNode {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodeId     String
  providerId String
  modelId    String
  nodeType   String
  settings   Json?
  position   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([projectId, nodeId])
}

model CanvasEdge {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  edgeId       String
  sourceNodeId String
  targetNodeId String
  sourcePort   String
  targetPort   String
  createdAt    DateTime @default(now())

  @@unique([projectId, edgeId])
}

model Job {
  id             String       @id @default(cuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  state          JobState     @default(queued)
  providerId     String
  modelId        String
  nodeRunPayload Json
  attempts       Int          @default(0)
  maxAttempts    Int          @default(3)
  errorCode      String?
  errorMessage   String?
  queuedAt       DateTime     @default(now())
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  attemptsLog    JobAttempt[]
  assets         Asset[]

  @@index([projectId, state, createdAt(sort: Desc)])
}

model JobAttempt {
  id               String   @id @default(cuid())
  jobId            String
  job              Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  attemptNumber    Int
  providerRequest  Json
  providerResponse Json?
  errorCode        String?
  errorMessage     String?
  durationMs       Int?
  createdAt        DateTime @default(now())

  @@unique([jobId, attemptNumber])
}

model Asset {
  id          String         @id @default(cuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  jobId       String?
  job         Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  type        AssetType
  storageRef  String
  mimeType    String
  outputIndex Int?
  width       Int?
  height      Int?
  durationMs  Int?
  checksum    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  feedback    AssetFeedback?
  tags        AssetTagLink[]

  @@index([projectId, createdAt(sort: Desc)])
}

model AssetFeedback {
  assetId   String   @id
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  rating    Int?
  flagged   Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model AssetTag {
  id        String         @id @default(cuid())
  projectId String
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime       @default(now())
  assets    AssetTagLink[]

  @@unique([projectId, name])
}

model AssetTagLink {
  assetId   String
  tagId     String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tag       AssetTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([assetId, tagId])
}

model ProviderModel {
  providerId   String
  modelId      String
  displayName  String
  capabilities Json
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@id([providerId, modelId])
}
